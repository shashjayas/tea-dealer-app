# Build stage
FROM maven:3.9-eclipse-temurin-11 AS build
WORKDIR /app
COPY tea-dealer-backend/pom.xml .
COPY tea-dealer-backend/src ./src
RUN mvn clean package -DskipTests

# Run stage
FROM eclipse-temurin:11-jre
WORKDIR /app
COPY --from=build /app/target/tea-dealer-backend-0.0.1-SNAPSHOT.jar app.jar
EXPOSE 8080
ENTRYPOINT ["java", "-jar", "app.jar"]
